# CourtBook server environment (blueprint §10). Copy to .env for local dev.
# Server reads .env via `node --env-file` — no dotenv dependency.

NODE_ENV=development
PORT=3000

# MongoDB Atlas in prod; docker-compose mongo locally
MONGO_URI=mongodb://localhost:27017/courtbook

# CORS allowlist — the SPA origin(s), comma-separated
CLIENT_ORIGIN=http://localhost:5173

# ── Used from M1 (auth) onward — optional until then ──
JWT_SECRET=change-me
REFRESH_SECRET=change-me-too

# ── M2+: Cloudinary signed uploads ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── M1+: outbox emails go via SMTP — mailhog locally, real provider in prod ──
SMTP_URL=smtp://localhost:1025
EMAIL_FROM=CourtBook <no-reply@courtbook.local>
RESEND_KEY=

# ── M4: payment gateways (sandbox) ──
ESEWA_SECRET=
KHALTI_SECRET=

# ── M7: AI assistant ──
LLM_API_KEY=

# ── Observability (optional everywhere) ──
SENTRY_DSN=
LOG_LEVEL=info
